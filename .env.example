# ============================================
# BEAVER SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# DATABASE CONFIGURATION (MySQL)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=beaver_dev
DB_USER=root
DB_PASSWORD=1234567891011
DB_SSL=false

# ============================================
# AUTH & SECURITY
# ============================================
JWT_SECRET=change-this-to-a-very-long-secret-at-least-32-characters
JWT_EXPIRES_IN=59m
REFRESH_TOKEN_SECRET=change-this-refresh-secret-to-a-very-long-secret
REFRESH_TOKEN_EXPIRY=7d
REFRESH_TOKEN_EXPIRY_SECONDS=604800
INVITE_TOKEN_SECRET=change-this-invite-secret-to-a-very-long-secret
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CLUSTER=false
WORKERS=4
WORKER_50=false
ENABLE_CSP=true
ENABLE_CORS=true
ENABLE_SECURITY_MW=true
ENABLE_RATE_LIMIT=true
ENABLE_CRON=true
ENABLE_SLOW_QUERY_LOG=true
ENABLE_API_TRACKING=true
ENABLE_IMAGE_COMPRESSION=true
ENABLE_SWAGGER=true
ENABLE_COMPRESSION=true
ENABLE_SMTP=true
ENABLE_ACTION_LOGGING=true
LOG_LEVEL=debug

# ============================================
# RATE LIMITING
# ============================================
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@beaver.rent

# ============================================
# RAZORPAY
# ============================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# CRON & PAYMENTS
# ============================================
CRON_TIMEZONE=Asia/Kolkata
DUES_CRON_SCHEDULE=0 8 * * *
AGREEMENT_EXPIRY_CRON_SCHEDULE=0 1 * * *
OVERDUE_REMINDER_CRON_SCHEDULE=0 9 * * *
DEFAULT_GST_RATE=18

# ============================================
# PDF GENERATION
# ============================================
PDF_TIMEOUT=30000
